# ============================================
# ReupBanConten - Environment Configuration
# ============================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# === LLM Providers ===
# OpenAI (optional - if using GPT models)
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

# Anthropic Claude (optional)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Ollama (default - local, free)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# === Default LLM Provider ===
# Options: ollama, openai, anthropic
LLM_PROVIDER=ollama

# === Whisper Configuration ===
# Model sizes: tiny, base, small, medium, large-v3
WHISPER_MODEL=large-v3
WHISPER_DEVICE=cuda
WHISPER_LANGUAGE=vi

# === YouTube Configuration ===
# YouTube Data API (optional - for advanced metadata)
YOUTUBE_API_KEY=your-youtube-api-key-here

# === ElevenLabs Voiceover ===
# Get API key from https://elevenlabs.io
ELEVENLABS_API_KEY=your-elevenlabs-api-key-here
ELEVENLABS_DEFAULT_VOICE=Rachel
# Provider: elevenlabs (premium) or edge-tts (free fallback)
VOICEOVER_PROVIDER=elevenlabs

# === Paths ===
FFMPEG_PATH=ffmpeg
DATA_DIR=./data
DOWNLOAD_DIR=./data/downloads
CLIPS_DIR=./data/clips
OUTPUT_DIR=./data/outputs
CACHE_DIR=./data/cache

# === Download Settings ===
MAX_CONCURRENT_DOWNLOADS=3
DEFAULT_VIDEO_QUALITY=720p
MAX_VIDEO_DURATION=180

# === Processing ===
# GPU acceleration
USE_GPU=true
GPU_DEVICE=0

# === Logging ===
LOG_LEVEL=INFO
LOG_FILE=./logs/reupbanconten.log
